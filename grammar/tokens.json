{
  "charsets": {
    "digit": "0123456789",
    "letter": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ",
    "blank": " \t\r\n",
    "string_char": "!#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~ \t",
    "cjk": ""
  },
  "keywords": {
    "int": "INT",
    "float": "FLOAT",
    "string": "STRING",
    "if": "IF",
    "else": "ELSE",
    "while": "WHILE",
    "for": "FOR",
    "print": "PRINT",
    "printn": "PRINTN",
    "input": "INPUT",
    "write": "WRITE",
    "return": "RETURN",
    "break": "BREAK",
    "continue": "CONTINUE"
  },
  "operators": {
    "==": "EQ",
    "!=": "NE",
    "<=": "LE",
    ">=": "GE",
    "&&": "AND",
    "||": "OR",
    "+": "PLUS",
    "-": "MINUS",
    "*": "STAR",
    "/": "SLASH",
    "=": "ASSIGN",
    "<": "LT",
    ">": "GT",
    "!": "NOT",
    "(": "LPAREN",
    ")": "RPAREN",
    "{": "LBRACE",
    "}": "RBRACE",
    "[": "LBRACKET",
    "]": "RBRACKET",
    ";": "SEMI",
    ",": "COMMA"
  },
  "patterns": [
    {"name": "STRING_LIT", "regex": "\"(string_char|cjk)*\""},
    {"name": "FLOAT_LIT", "regex": "digit+\\.digit+"},
    {"name": "INT_LIT", "regex": "digit+"},
    {"name": "IDENT", "regex": "(letter|_)((letter|digit|_))*"},
    {"name": "WHITESPACE", "regex": "blank+", "skip": true}
  ]
}
