{
  "description": "MiniLang 词法规则库 — 参考 CompilationPrinciple 项目的 DFA/正则思路，用正则模式定义 Token",
  "keywords": {
    "int": "INT",
    "float": "FLOAT",
    "if": "IF",
    "else": "ELSE",
    "while": "WHILE",
    "print": "PRINT",
    "return": "RETURN"
  },
  "operators": {
    "+": "PLUS",
    "-": "MINUS",
    "*": "STAR",
    "/": "SLASH",
    "=": "ASSIGN",
    "==": "EQ",
    "!=": "NE",
    "<": "LT",
    "<=": "LE",
    ">": "GT",
    ">=": "GE",
    "(": "LPAREN",
    ")": "RPAREN",
    "{": "LBRACE",
    "}": "RBRACE",
    ";": "SEMI",
    ",": "COMMA"
  },
  "patterns": [
    {"name": "FLOAT_LIT", "regex": "\\d+\\.\\d+"},
    {"name": "INT_LIT", "regex": "\\d+"},
    {"name": "IDENT", "regex": "[a-zA-Z_][a-zA-Z0-9_]*"},
    {"name": "WHITESPACE", "regex": "[ \\t\\r\\n]+", "skip": true},
    {"name": "COMMENT", "regex": "//[^\\n]*", "skip": true}
  ]
}
