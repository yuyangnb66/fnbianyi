{
  "description": "MiniLang 语法规则库 (BNF) — 供文档与语法分析参考",
  "start": "Program",
  "productions": {
    "Program": [["StmtList"]],
    "StmtList": [["Stmt", "StmtList"], []],
    "Stmt": [
      ["DeclStmt"],
      ["AssignStmt"],
      ["IfStmt"],
      ["WhileStmt"],
      ["PrintStmt"],
      ["Block"]
    ],
    "DeclStmt": [["Type", "IDENT", "SEMI"]],
    "AssignStmt": [["IDENT", "ASSIGN", "Expr", "SEMI"]],
    "IfStmt": [
      ["IF", "LPAREN", "Expr", "RPAREN", "Block"],
      ["IF", "LPAREN", "Expr", "RPAREN", "Block", "ELSE", "Block"]
    ],
    "WhileStmt": [["WHILE", "LPAREN", "Expr", "RPAREN", "Block"]],
    "PrintStmt": [["PRINT", "LPAREN", "Expr", "RPAREN", "SEMI"]],
    "Block": [["LBRACE", "StmtList", "RBRACE"]],
    "Type": [["INT"], ["FLOAT"]],
    "Expr": [
      ["Term", "AddOp", "Expr"],
      ["Term"]
    ],
    "AddOp": [["PLUS"], ["MINUS"]],
    "Term": [
      ["Factor", "MulOp", "Term"],
      ["Factor"]
    ],
    "MulOp": [["STAR"], ["SLASH"]],
    "Factor": [
      ["INT_LIT"],
      ["FLOAT_LIT"],
      ["IDENT"],
      ["LPAREN", "Expr", "RPAREN"],
      ["MINUS", "Factor"]
    ],
    "RelExpr": [
      ["Expr", "RelOp", "Expr"],
      ["Expr"]
    ],
    "RelOp": [["EQ"], ["NE"], ["LT"], ["LE"], ["GT"], ["GE"]]
  },
  "notes": "实际解析器使用递归下降；条件表达式 RelExpr 在 If/While 中使用"
}
